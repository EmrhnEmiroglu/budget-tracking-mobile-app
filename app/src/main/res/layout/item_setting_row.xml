<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:minHeight="56dp">

    <TextView
        android:id="@+id/tv_row_icon"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_setting_icon"
        android:gravity="center"
        android:text="⚙"
        android:textSize="18sp"
        android:layout_marginEnd="14dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_row_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ayar"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="normal" />

        <TextView
            android:id="@+id/tv_row_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Arrow (default, for navigation rows) -->
    <TextView
        android:id="@+id/tv_row_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="›"
        android:textColor="@color/nav_inactive"
        android:textSize="22sp"
        android:visibility="visible" />

    <!-- Toggle switch (for toggle rows) -->
    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/sw_row_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

</LinearLayout>
